# This file is for local development.
# On Railway: set these in your service "Variables" (no .env file needed).

# --- Core ---
NODE_ENV=development
APP_NAME=LearnBridge
APP_NAME_SHORT=LearnBridge
SUPPORT_EMAIL=support@learnbridge.com

# Not used by the Node app (kept for nginx/template tooling):
# DOMAIN_NAME=api.learnbridge.local

# Railway sets PORT automatically. Only use locally if needed:
# PORT=4000

# --- Database (PostgreSQL) ---
# Railway option (recommended): use a single DATABASE_URL variable:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?schema=public

# Local option: discrete settings (used if DATABASE_URL is not set):
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=learnbridge

# On Railway, managed DBs typically do not allow DB creation and you usually don't want auto-alter:
# DB_CREATE_IF_MISSING=true
# DB_SYNC_ALTER=true

# --- Auth / Tokens ---
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# --- Super Admin bootstrap (optional — created automatically on first run) ---
SUPER_ADMIN_EMAIL=superadmin@learnbridge.local
SUPER_ADMIN_PASSWORD=SuperStrongPassword123!

# --- OTP / Reset ---
OTP_EXPIRY_MINUTES=10
RESET_EXPIRY_MINUTES=30
OTP_RESEND_COOLDOWN_SECONDS=60

# --- Rate limits / Body ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX=30
JSON_BODY_LIMIT=1mb

# --- CORS / Security headers ---
CORS_ORIGIN=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CROSS_ORIGIN_RESOURCE_POLICY=cross-origin
CSP_ENABLED=true
CSP_REPORT_ONLY=false
CSP_ALLOW_UNSAFE_INLINE=false

# Security.txt endpoint
SECURITY_CONTACT_EMAIL=security@LearnBridge.com
SECURITY_CONTACT_URL=
SECURITY_POLICY_URL=
SECURITY_ACK_URL=
SECURITY_EXPIRES=

# --- URLs ---
SWAGGER_SERVER_URL=http://localhost:4000
PUBLIC_BASE_URL=http://localhost:4000

# --- Uploads ---
# Required: the app refuses to boot if this is empty.
UPLOAD_DIR=uploads
UPLOAD_MAX_MB=100
UPLOAD_ALLOWED_MIME=application/pdf,application/zip,image/png,image/jpeg

# --- Courses / Quizzes ---
DEFAULT_CURRENCY=USD
COURSE_UPLOAD_MAX_GB=10
COURSE_UPLOAD_ALLOWED_EXT=mp4,pdf,md,txt
QUIZ_PRAISE_THRESHOLD=85
QUIZ_AVG_THRESHOLD=60
SUBMISSION_URGENT_DAYS=3

# --- Dev-only endpoints ---
DEV_EMAIL_PREVIEW=true
DEV_CERT_PREVIEW=true

# --- Dev DB seed (never enable in production) ---
# SEED_DEV_DATA=true
# SEED_RESET=true

# --- Redis (optional) ---
# For Railway, set REDIS_URL from the Railway Redis service and enable it:
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# Fallback discrete Redis settings (used by BullMQ if REDIS_URL isn't set):
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=false

# --- Email queue (optional; requires Redis) ---
EMAIL_QUEUE_ENABLED=false
EMAIL_QUEUE_NAME=email-jobs

# --- Audit log circuit-breaker ---
AUDIT_LOG_WINDOW_MS=60000
AUDIT_LOG_RATE_LIMIT=60
AUDIT_LOG_FAILURE_THRESHOLD=5
AUDIT_LOG_COOLDOWN_MS=120000

# --- Certificates / Puppeteer ---
CERT_SIGNATORY_NAME=LearnBridge Team
CERT_SIGNATORY_TITLE=Program Director
CERT_ACCREDITATION_LABEL=LearnBridge Verified
CERT_SEAL_LABEL=Official Seal
CERT_WATERMARK_URL=
CERT_SEAL_LOGO_URL=
CERT_QR_CODE_URL=
CERT_PDF_LANDSCAPE=true
CERT_SIGNATURE_MODE=auto
CERT_CACHE_ENABLED=true
CERT_IMAGE_CACHE_DIR=

# Railway/Linux containers often need this for Puppeteer:
PUPPETEER_DISABLE_SANDBOX=false

# --- OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_CALLBACK_BASE=http://localhost:4000
OAUTH_SUCCESS_REDIRECT=

# --- SMTP (optional) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="LearnBridge <no-reply@learnbridge.com>"

# --- Branding (used in email templates and notification links) ---
BRAND_PRIMARY=#0B5FFF
BRAND_ACCENT=#FFFFFF
BRAND_LOGO_URL=
BRAND_APP_URL=http://localhost:3000

# --- NGINX template vars (not used by the Node app; kept for deploy/nginx.conf.template) ---
# NGINX_UPLOADS_PATH=
# NGINX_CLIENT_MAX_BODY_SIZE=100m
# NGINX_CLIENT_BODY_TIMEOUT=60s
# NGINX_HSTS_MAX_AGE=31536000
# NGINX_CSP=default-src 'self'
# NGINX_X_FRAME_OPTIONS=DENY
# NGINX_X_CONTENT_TYPE_OPTIONS=nosniff
# NGINX_REFERRER_POLICY=no-referrer
# NGINX_PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=(), payment=()
# NGINX_GZIP=on
# NGINX_GZIP_TYPES=text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript image/svg+xml
# NGINX_GZIP_MIN_LENGTH=1024
# NGINX_PROXY_READ_TIMEOUT=60s
# NGINX_PROXY_SEND_TIMEOUT=60s
# NGINX_PROXY_BUFFERING=off
# NGINX_WS_READ_TIMEOUT=300s
# NGINX_WS_SEND_TIMEOUT=300s
# NGINX_UPLOADS_CACHE_SECONDS=86400

REQUIRE_LOGIN_OTP=false
